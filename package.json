{
  "name": "medieval-life-sim",
  "version": "0.1.0",
  "description": "Exhaustive medieval life simulation with naturalistic physics and emergent gameplay",
  "type": "module",
  "main": "src/main.js",
  "scripts": {
    "start": "node src/main-blessed.js",
    "dev": "node --watch src/main-blessed.js",
    "test": "node --test \"tests/*.test.js\"",
    "test:ci": "node --test \"tests/*.test.js\" --test-reporter=spec",
    "determinism-audit": "node scripts/audit-determinism.js",
    "cargo:build": "cargo build --manifest-path crates/sim/Cargo.toml --bins",
    "cargo:test": "cargo test --manifest-path crates/sim/Cargo.toml",
    "parity": "cargo run --quiet --bin parity-check --manifest-path crates/sim/Cargo.toml",
    "oracle:node": "node parity/oracle.mjs",
    "oracle:rust": "cargo run --quiet --bin oracle --manifest-path crates/sim/Cargo.toml"
  },
  "keywords": [
    "simulation",
    "medieval",
    "life-sim",
    "procedural",
    "emergent"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "blessed": "^0.1.81",
    "blessed-contrib": "^4.11.0",
    "htm": "^3.1.1",
    "ink": "^5.2.1",
    "ink-big-text": "^2.0.0",
    "ink-box": "^1.0.0",
    "ink-divider": "^4.1.1",
    "ink-gradient": "^3.0.0",
    "ink-link": "^4.1.0",
    "ink-progress-bar": "^1.0.2",
    "ink-select-input": "^6.2.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "react": "^18.3.1"
  }
}
